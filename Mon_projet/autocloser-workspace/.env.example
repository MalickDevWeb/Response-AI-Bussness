# ============================================================
# AUTOCLOSER AI - Variables d'Environnement (Mois 1)
# IMPORTANT : Copiez ce fichier en ".env" et remplissez les valeurs
# ============================================================

# --- SERVEUR ---
NODE_ENV=development
PORT=3000

# --- BASE DE DONNÉES (PostgreSQL local via Docker) ---
DATABASE_URL=postgresql://postgres:super_password_123@localhost:5432/autocloser
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=super_password_123
POSTGRES_DB=autocloser

# --- REDIS (File d'attente des messages) ---
REDIS_URL=redis://localhost:6379

# --- IA LOCALE (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
# Modèle pour le texte et la discussion
OLLAMA_TEXT_MODEL=mistral
# Modèle pour l'analyse des reçus (vision)
OLLAMA_VISION_MODEL=llama3.2-vision

# --- EVOLUTION API (Passerelle WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=AutocloserSecretKey2026

# --- NOTIFICATIONS EMAIL ---
# (Utiliser Resend.com - gratuit jusqu'à 3000 emails/mois)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notifications@autocloser.ai

# --- SÉCURITÉ ---
JWT_SECRET=un_secret_tres_long_et_complexe_a_changer_en_production
